POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=soundcloud
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/soundcloud

REDIS_URL=redis://redis:6379/0
PROCESSING_QUEUE=processing:jobs
MAX_JOB_RETRIES=5

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=us-east-1
MINIO_BUCKET=tracks
PRESIGN_EXPIRES_SECONDS=3600

CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8088
RATE_LIMIT=100/minute
CSRF_PROTECT=0

# Internal service-to-service auth token (optional, but recommended)
INTERNAL_API_TOKEN=change-me

# Firebase
FIREBASE_PROJECT_ID=replace-me
FIREBASE_CREDENTIALS_PATH=
AUTH_BYPASS=1
